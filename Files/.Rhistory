PintailRegion == "Northern breeding" & (is.na(percap_WTP) | is.infinite(percap_WTP)) ~ nd_sd_medA,
PintailRegion == "Alaska breeding"   & (is.na(percap_WTP) | is.infinite(percap_WTP)) ~ ca_or_medA,
